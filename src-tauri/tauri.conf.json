{
    "$schema": "https://tauri.app/v1/api/config/schema.json",
    "build": {
        "beforeBuildCommand": "pnpm build",
        "beforeDevCommand": "pnpm dev",
        "devPath": "http://localhost:5173",
        "distDir": "../dist"
    },
    "package": {
        "productName": "Jiujing",
        "version": "1.0.0"
    },
    "tauri": {
        "windows": [
            {
                "title": "Jiujing"
            }
        ],
        "bundle": {
            "active": true,
            "targets": [
                "nsis",
                "msi"
            ]
        }
    }
}