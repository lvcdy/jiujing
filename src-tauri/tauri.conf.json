{
    "$schema": "https://tauri.app/schema.json",
    "identifier": "com.lvcdy.jiujing",
    "productName": "Jiujing",
    "version": "1.0.0",
    "build": {
        "beforeBuildCommand": "pnpm build",
        "beforeDevCommand": "pnpm dev"
    },
    "app": {
        "windows": [
            {
                "title": "Jiujing",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": [],
        "externalBin": [],
        "copyright": "",
        "category": "DeveloperTool",
        "shortDescription": "",
        "longDescription": "",
        "macOS": {
            "frameworks": [],
            "minimumSystemVersion": "10.13",
            "exceptionDomain": "",
            "signingIdentity": null,
            "entitlements": null
        },
        "windows": {
            "certificateThumbprint": null,
            "digestAlgorithm": "sha256",
            "timestampUrl": ""
        }
    }
}