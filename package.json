{
  "name": "my-vue-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "big.js": "^7.0.1",
    "vue": "^3.5.31",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.3",
    "vue-tsc": "^3.2.6"
  },
  "build": {
    "appId": "com.lvcdy.jiujing.electron",
    "productName": "Jiujing Electron",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "directories": {
      "output": "release/electron"
    },
    "win": {
      "target": "zip"
    },
    "artifactName": "jiujing-electron-${version}-windows-${arch}.${ext}"
  }
}