{
  "name": "jiujing-calculator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:dist": "pnpm build && electron-builder"
  },
  "dependencies": {
    "big.js": "^7.0.1",
    "i18next": "^26.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/big.js": "^6.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-oxc": "^0.4.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^24.13.3",
    "typescript": "~5.9.3",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.lvcdy.jiujing.electron",
    "productName": "酒精浓度计算器",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "directories": {
      "output": "release/electron"
    },
    "win": {
      "target": "zip"
    },
    "artifactName": "jiujing-${version}-windows-${arch}.${ext}"
  }
}