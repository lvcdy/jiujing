{
  "name": "my-vue-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:pack": "pnpm build && electron-builder --dir",
    "electron:dist": "pnpm build && electron-builder"
  },
  "dependencies": {
    "big.js": "^7.0.1",
    "vue": "^3.5.31",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/big.js": "^6.2.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^23.6.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.3",
    "vue-tsc": "^3.2.6",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.lvcdy.jiujing.electron",
    "productName": "Jiujing",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "directories": {
      "output": "release/electron"
    },
    "win": {
      "target": "zip"
    },
    "artifactName": "jiujing-${version}-windows-${arch}.${ext}"
  }
}